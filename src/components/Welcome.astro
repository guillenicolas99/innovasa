---
import {servicios} from "../data.json"
import Card from "../components/Card.astro";
---

<section class="py-10">
  <div id="px-5 mx-auto max-w-screen-xl">
    <main class="flex flex-col items-center justify-center">
      <h1 class="text-2xl font-bold text-gray-900 text-center mb-5">
        Bienvenido a Innova SA
      </h1>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {servicios.map((link) => <Card href={link.slug} text={link.title} image={link.image} />)}
      </div>
    </main>
  </div>
</section>
