---
import ButtonBlue from "./ButtonBlue.astro";

const { href, text, image } = Astro.props;
---

<article class="max-w-sm bg-white rounded-lg shadow-sm text-center p-5 flex flex-col justify-between transition-transform duration-300 hover:scale-105 hover:shadow-lg">
  <a href={href} class="text-center w-full mx-auto">
    <img
      class="rounded-t-lg text-center mx-auto"
      src={image}
      alt=""
      transition:name={href.toLowerCase()}
    />
  </a>
  <div>
    <a href={href}>
      <h5 class="mb-2 text-2xl font-bold tracking-tight text-gray-900">
        {text}
      </h5>
    </a>
    <ButtonBlue content="Leer más" href={href}>
      Leer más
      <svg
        class="rtl:rotate-180 w-3.5 h-3.5 ms-2"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 14 10"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M1 5h12m0 0L9 1m4 4L9 9"></path>
      </svg>
    </ButtonBlue>
  </div>
</article>
