---
const Links = [
  {
    href: "/retos",
    text: "Retos",
  },
  {
    href: "/tableros-de-mando",
    text: "Tableros de mando",
  },
  {
    href: "/estrategias",
    text: "Estrategias",
  },
  {
    href: "/indicadores",
    text: "Indicadores",
  },
];
import Card from "../components/Card.astro";
---

<section class="py-10">
  <div id="container">
    <main class="flex flex-col items-center justify-center">
      <h1 class="text-2xl font-bold text-gray-700 text-center mb-5">
        Bienvenido a Innova SA
      </h1>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
        {Links.map((link) => <Card href={link.href} text={link.text} />)}
      </div>
    </main>
  </div>
</section>
