---
import ButtonBlue from "./ButtonBlue.astro";

const { href, text } = Astro.props;
---

<article class="max-w-sm bg-white rounded-lg shadow-sm">
  <a href={href}>
    <img
      class="rounded-t-lg"
      src="https://flowbite.com/docs/images/blog/image-1.jpg"
      alt=""
      transition:name={`hero-${text.toLowerCase()}`}
    />
  </a>
  <div class="p-5">
    <a href={href}>
      <h5 class="mb-2 text-2xl font-bold tracking-tight text-gray-900">
        {text}
      </h5>
    </a>
    <ButtonBlue content="Leer más" href={href}>
      Leer más
      <svg
        class="rtl:rotate-180 w-3.5 h-3.5 ms-2"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 14 10"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M1 5h12m0 0L9 1m4 4L9 9"></path>
      </svg>
    </ButtonBlue>
  </div>
</article>
